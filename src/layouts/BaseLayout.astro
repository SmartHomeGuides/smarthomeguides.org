---
import "@/styles/global.css";
import type { Locale } from "@i18n/index";
import { t, languages } from "@i18n/index";
import { getBase } from "@lib/guides";
import { SITE_NAME, SITE_URL, UNDER_CONSTRUCTION } from "@lib/consts";
import SearchModal from "@components/SearchModal.astro";
import UnderConstructionBanner from "@components/UnderConstructionBanner.astro";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  canonicalOverride?: string;
  ogImage?: string;
}

const {
  title,
  description = t("en", "site.description"),
  locale = "en",
  canonicalOverride,
  ogImage: ogImageProp,
} = Astro.props;

const base = getBase();
const siteName = SITE_NAME;
const pageTitle = title
  ? `${title} — ${siteName}`
  : `${siteName} — ${t(locale, "home.hero.title")}`;

// Canonical URL
const siteOrigin = Astro.site?.origin ?? SITE_URL;
const canonicalUrl = canonicalOverride
  ? new URL(canonicalOverride, siteOrigin).href
  : new URL(Astro.url.pathname, siteOrigin).href;

// Hreflang alternates
const pathname = Astro.url.pathname;
const localeSegmentRe = /^(\/smarthomeguides\.org\/)(en|fr)(\/.*)?$/;
const match = pathname.match(localeSegmentRe);
const isRoot = pathname === base || pathname === base.replace(/\/$/, "");
const alternates =
  match || isRoot
    ? Object.keys(languages).map((lang) => ({
        lang,
        href: match
          ? new URL(`${match[1]}${lang}${match[3] ?? ""}`, siteOrigin).href
          : new URL(`${base}${lang}/`, siteOrigin).href,
      }))
    : [];

// OG locale format (e.g. "en_US")
const ogLocaleMap: Record<string, string> = { en: "en_US", fr: "fr_FR" };
const ogLocale = ogLocaleMap[locale] ?? "en_US";

// OG image: use per-page image if provided, otherwise fall back to locale default
const ogImage = ogImageProp
  ? new URL(`${base}${ogImageProp}`, siteOrigin).href
  : new URL(`${base}og/${locale}/og-default.webp`, siteOrigin).href;

// JSON-LD WebSite
const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: new URL(base, siteOrigin).href,
  inLanguage: locale,
});
---

<!doctype html>
<html lang={locale} data-theme="lofi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="theme-color"
      content="#4f46e5"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#312e81"
      media="(prefers-color-scheme: dark)"
    />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicons */}
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />

    {/* Hreflang alternates */}
    {
      alternates.map(({ lang, href }) => (
        <link rel="alternate" hreflang={lang} href={href} />
      ))
    }
    {
      alternates.length > 0 && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={alternates.find((a) => a.lang === "en")?.href ?? canonicalUrl}
        />
      )
    }

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD */}
    <script is:inline type="application/ld+json" set:html={websiteSchema} />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: light)").matches
            ? "lofi"
            : "sunset");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    {UNDER_CONSTRUCTION && <UnderConstructionBanner locale={locale} />}
    <slot />
    <SearchModal locale={locale} />
  </body>
</html>

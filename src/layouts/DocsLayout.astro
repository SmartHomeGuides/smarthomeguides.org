---
import SidebarLayout from "@layouts/SidebarLayout.astro";
import MiniToc from "@components/MiniToc.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import GuideNav from "@components/GuideNav.astro";
import GitInfo from "@components/GitInfo.astro";
import Giscus from "@components/Giscus.astro";
import ReadingProgress from "@components/ReadingProgress.astro";
import type { Locale } from "@i18n/index";
import type { Category, GuideGroup } from "@lib/guides";
import { getBase } from "@lib/guides";
import { SITE_NAME, SITE_URL } from "@lib/consts";
import type { Contributor } from "@lib/git";

interface GuideLink {
  href: string;
  title: string;
}

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  category: Category;
  guideGroups: GuideGroup[];
  activeGuideSlug: string;
  activeChapterSlug?: string | null;
  guideTitle?: string;
  guideHref?: string;
  isGuideLanding?: boolean;
  headings: { depth: number; slug: string; text: string }[];
  editUrl?: string;
  issueUrl?: string;
  prev?: GuideLink;
  next?: GuideLink;
  lastModified?: Date;
  contributors?: Contributor[];
  ogImage?: string;
}

const {
  title,
  description,
  locale,
  category,
  guideGroups,
  activeGuideSlug,
  activeChapterSlug,
  guideTitle,
  guideHref,
  isGuideLanding,
  headings,
  editUrl,
  issueUrl,
  prev,
  next,
  lastModified,
  contributors = [],
  ogImage,
} = Astro.props;

const base = getBase();
const siteOrigin = Astro.site?.origin ?? SITE_URL;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description ?? "",
  inLanguage: locale,
  url: new URL(Astro.url.pathname, siteOrigin).href,
  ...(lastModified && { dateModified: lastModified.toISOString() }),
  author: {
    "@type": "Organization",
    name: SITE_NAME,
    url: new URL(base, siteOrigin).href,
  },
});
---

<SidebarLayout
  title={title}
  description={description}
  locale={locale}
  category={category}
  guideGroups={guideGroups}
  activeGuideSlug={activeGuideSlug}
  activeChapterSlug={activeChapterSlug}
  headings={headings}
  editUrl={editUrl}
  issueUrl={issueUrl}
  ogImage={ogImage}
>
  <script type="application/ld+json" is:inline set:html={articleSchema} />
  <ReadingProgress />
  <div class="mx-auto w-full max-w-[1400px] flex-1">
    <main class="min-w-0 px-4 pt-4 pb-6 lg:px-10 lg:pb-8" data-pagefind-body>
      <meta data-pagefind-filter="locale" content={locale} />
      <Breadcrumb
        locale={locale}
        category={category}
        guideTitle={isGuideLanding ? title : (guideTitle ?? title)}
        chapterTitle={guideTitle && !isGuideLanding ? title : undefined}
        guideHref={guideHref}
      />
      <div class="mt-4">
        <GitInfo
          locale={locale}
          lastModified={lastModified}
          contributors={contributors}
        />
      </div>
      <div class="prose mt-6">
        <slot />
      </div>
      <GuideNav locale={locale} prev={prev} next={next} />
      <Giscus
        locale={locale}
        term={`${locale}/guides/${category}/${activeGuideSlug}${activeChapterSlug ? `/${activeChapterSlug}` : ""}`}
      />
    </main>
  </div>
  <MiniToc headings={headings} />
</SidebarLayout>

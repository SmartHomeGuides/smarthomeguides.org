---
import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import CategoryTabs from "@components/CategoryTabs.astro";
import Sidebar from "@components/Sidebar.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import GuideNav from "@components/GuideNav.astro";
import Footer from "@components/Footer.astro";
import GitInfo from "@components/GitInfo.astro";
import Giscus from "@components/Giscus.astro";
import type { Locale } from "@i18n/index";
import type { Category } from "@lib/guides";
import type { Contributor } from "@lib/git";
import type { CollectionEntry } from "astro:content";

interface GuideLink {
  href: string;
  title: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  category: Category;
  guides: CollectionEntry<"docs">[];
  activeSlug: string;
  headings: Heading[];
  editUrl?: string;
  issueUrl?: string;
  prev?: GuideLink;
  next?: GuideLink;
  lastModified?: Date;
  contributors?: Contributor[];
}

const {
  title,
  description,
  locale,
  category,
  guides,
  activeSlug,
  headings,
  editUrl,
  issueUrl,
  prev,
  next,
  lastModified,
  contributors = [],
} = Astro.props;
---

<BaseLayout title={title} description={description} locale={locale}>
  <div class="drawer lg:drawer-open">
    <input id="sidebar-drawer" type="checkbox" class="drawer-toggle" />

    {/* Main content area (navbar + tabs + center + right) */}
    <div class="drawer-content flex min-h-screen flex-col">
      <Navbar locale={locale} />
      <CategoryTabs locale={locale} activeCategory={category} />

      <div class="mx-auto w-full max-w-[1400px] flex-1">
        <div class="grid grid-cols-1 xl:grid-cols-[1fr_250px]">
          {/* Center: article */}
          <main class="min-w-0 px-4 py-6 lg:px-10 lg:py-8" data-pagefind-body>
            <meta data-pagefind-filter="locale" content={locale} />
            <Breadcrumb
              locale={locale}
              category={category}
              guideTitle={title}
            />
            <div class="mt-4">
              <GitInfo
                locale={locale}
                lastModified={lastModified}
                contributors={contributors}
              />
            </div>
            <div class="prose mt-6">
              <slot />
            </div>
            <Giscus
              locale={locale}
              term={`${locale}/guides/${category}/${activeSlug}`}
            />
            <GuideNav locale={locale} prev={prev} next={next} />
          </main>

          {/* Right panel: TOC */}
          <aside class="hidden border-l border-base-300 xl:block">
            <div
              class="sticky top-[112px] h-[calc(100vh-112px)] overflow-y-auto p-4"
            >
              <TableOfContents
                headings={headings}
                locale={locale}
                editUrl={editUrl}
                issueUrl={issueUrl}
              />
            </div>
          </aside>
        </div>
      </div>

      <Footer locale={locale} />
    </div>

    {/* Left sidebar (drawer on mobile, visible on lg+) */}
    <div class="drawer-side z-50">
      <label
        for="sidebar-drawer"
        class="drawer-overlay"
        aria-label="Close sidebar"></label>
      <aside
        class="min-h-full w-[250px] border-r border-base-300 bg-base-100 p-4 pt-6"
      >
        <Sidebar
          locale={locale}
          category={category}
          guides={guides}
          activeSlug={activeSlug}
        />
      </aside>
    </div>
  </div>
</BaseLayout>

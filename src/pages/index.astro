---
import BaseLayout from "@layouts/BaseLayout.astro";
import HomeContent from "@components/HomeContent.astro";
import { t, languages } from "@i18n/index";
import { getBase } from "@lib/guides";

const locale = "en";
const base = getBase();
---

<BaseLayout
  title={t(locale, "home.hero.title")}
  locale={locale}
  canonicalOverride={`${base}en/`}
>
  <HomeContent locale={locale} />

  <script
    is:inline
    data-supported={JSON.stringify(Object.keys(languages))}
    data-base={base}
  >
    (function () {
      const script = document.currentScript;
      const supported = JSON.parse(script.dataset.supported);
      const base = script.dataset.base;
      const lang = (navigator.language || "").split("-")[0];
      const target = supported.indexOf(lang) !== -1 ? lang : "en";
      if (
        window.location.pathname === base ||
        window.location.pathname === base.slice(0, -1)
      ) {
        window.location.replace(base + target + "/");
      }
    })();
  </script>
</BaseLayout>

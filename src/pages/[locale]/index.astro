---
import BaseLayout from "@layouts/BaseLayout.astro";
import HomeContent from "@components/HomeContent.astro";
import { t, languages } from "@i18n/index";
import type { Locale } from "@i18n/index";

export function getStaticPaths() {
  return Object.keys(languages).map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params as { locale: Locale };
---

<BaseLayout title={t(locale, "home.hero.title")} locale={locale}>
  <HomeContent locale={locale} />
</BaseLayout>

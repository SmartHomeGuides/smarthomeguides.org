---
import SidebarLayout from "@layouts/SidebarLayout.astro";
import { t, languages } from "@i18n/index";
import type { Locale } from "@i18n/index";
import {
  getAllGuidesForLocale,
  getGuideSlug,
  getGuideCategory,
  getBase,
} from "@lib/guides";
import { getAllContributorProfiles } from "@lib/git";
import type { ContributorRank } from "@lib/git";
import { Trophy, Award, Star, Sprout } from "@lucide/astro";

export function getStaticPaths() {
  return Object.keys(languages).map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params as { locale: Locale };
const base = getBase();

const allDocs = await getAllGuidesForLocale(locale);
const guides = allDocs.map((doc) => ({
  filePath: doc.filePath ?? "",
  title: doc.data.title,
  href: `${base}${locale}/guides/${getGuideCategory(doc.id)}/${getGuideSlug(doc.id)}`,
}));

const contributors = await getAllContributorProfiles(guides);

const rankBadgeClass: Record<ContributorRank, string> = {
  champion: "badge-warning",
  advocate: "badge-secondary",
  contributor: "badge-primary",
  newcomer: "badge-ghost",
};

const RankIcon: Record<ContributorRank, typeof Trophy> = {
  champion: Trophy,
  advocate: Award,
  contributor: Star,
  newcomer: Sprout,
};
---

<SidebarLayout title={t(locale, "contributors.title")} locale={locale}>
  <main class="mx-auto max-w-5xl flex-1 px-4 py-12" data-pagefind-ignore>
    <h1 class="text-4xl font-bold">{t(locale, "contributors.title")}</h1>
    <p class="mt-2 text-base-content/70">
      {t(locale, "contributors.description")}
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        contributors.map((c) => {
          const Icon = RankIcon[c.rank];
          return (
            <div class="card bg-base-200 shadow-sm">
              <div class="card-body items-center text-center">
                <div class="avatar">
                  <div class="w-20 rounded-full">
                    {c.profileUrl ? (
                      <a
                        href={c.profileUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <img
                          src={c.avatarUrl}
                          alt={c.name}
                          width="80"
                          height="80"
                          loading="lazy"
                        />
                      </a>
                    ) : (
                      <img
                        src={c.avatarUrl}
                        alt={c.name}
                        width="80"
                        height="80"
                        loading="lazy"
                      />
                    )}
                  </div>
                </div>

                <h2 class="card-title text-lg">
                  {c.profileUrl ? (
                    <a
                      href={c.profileUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="link link-hover"
                    >
                      {c.name}
                    </a>
                  ) : (
                    c.name
                  )}
                </h2>

                <span class={`badge badge-sm gap-1 ${rankBadgeClass[c.rank]}`}>
                  <Icon class="h-3 w-3" />
                  {t(locale, `contributors.rank.${c.rank}` as const)}
                </span>

                <p class="text-sm text-base-content/60">
                  {t(locale, "contributors.mergedPRs", {
                    count: c.mergedPRs,
                  })}
                </p>

                {c.guides.length > 0 && (
                  <div class="mt-2 w-full text-left">
                    <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">
                      {t(locale, "contributors.guidesContributed")}
                    </p>
                    <ul class="mt-1 space-y-1">
                      {c.guides.map((g) => (
                        <li>
                          <a href={g.href} class="link link-hover text-sm">
                            {g.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </main>
</SidebarLayout>

---
import { getCollection, render } from "astro:content";
import DocsLayout from "@layouts/DocsLayout.astro";
import type { Locale } from "@i18n/index";
import {
  getGuideLocale,
  getGuideCategory,
  getGuideSlug,
  parseEntryId,
  isIndexEntry,
  getBase,
  getGroupedGuides,
  getGuideEntryUrl,
  buildLinearOrder,
} from "@lib/guides";
import type { Category } from "@lib/guides";
import { getLastModified, getContributors } from "@lib/git";

export async function getStaticPaths() {
  const allDocs = await getCollection(
    "docs",
    (entry) => !entry.data.draft && !isIndexEntry(entry.id),
  );

  return allDocs.map((entry) => ({
    params: {
      locale: getGuideLocale(entry.id),
      category: getGuideCategory(entry.id),
      slug: getGuideSlug(entry.id),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { locale, category } = Astro.params as {
  locale: Locale;
  category: Category;
};
const base = getBase();

const { Content, headings } = await render(entry);

// Grouped guides for sidebar
const guideGroups = await getGroupedGuides(locale, category);

// Linear order for prev/next navigation
const linearOrder = buildLinearOrder(guideGroups);
const currentSlug = getGuideSlug(entry.id);
const currentIndex = linearOrder.findIndex(
  (s) => getGuideSlug(s.id) === currentSlug,
);

function makeLink(index: number) {
  const guide = linearOrder[index];
  if (!guide) return undefined;
  return {
    href: getGuideEntryUrl(base, locale, category, guide),
    title: guide.data.title,
  };
}

const prev = currentIndex > 0 ? makeLink(currentIndex - 1) : undefined;
const next =
  currentIndex < linearOrder.length - 1
    ? makeLink(currentIndex + 1)
    : undefined;

// Active guide/chapter for sidebar highlighting
const parsed = parseEntryId(entry.id);
const activeGuideSlug = parsed.guideSlug;
const activeChapterSlug = parsed.chapterSlug;

// For multi-page guides, use guideTitle; for single-page, use title
const displayTitle = entry.data.guideTitle ?? entry.data.title;

// Breadcrumb: for chapters, link back to the guide (first chapter)
const activeGroup = guideGroups.find((g) => g.guideSlug === activeGuideSlug);
const guideHref =
  activeGroup && activeGroup.isMultiPage
    ? getGuideEntryUrl(base, locale, category, activeGroup.entries[0])
    : undefined;

// GitHub URLs
const repoBase = "https://github.com/smarthomeguides/smarthomeguides.org";
const filePath = entry.filePath ?? "";
const editUrl = `${repoBase}/edit/main/${filePath}`;
const issueUrl = `${repoBase}/issues/new?title=Issue+with:+${encodeURIComponent(entry.data.title)}`;

const lastModified = getLastModified(filePath);
const contributors = getContributors(filePath);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  category={category}
  guideGroups={guideGroups}
  activeGuideSlug={activeGuideSlug}
  activeChapterSlug={activeChapterSlug}
  guideTitle={activeGroup?.isMultiPage ? displayTitle : undefined}
  guideHref={guideHref}
  headings={headings}
  editUrl={editUrl}
  issueUrl={issueUrl}
  prev={prev}
  next={next}
  lastModified={lastModified}
  contributors={contributors}
>
  <Content />
</DocsLayout>

---
import { render } from "astro:content";
import { REPO_URL } from "@lib/consts";
import SidebarLayout from "@layouts/SidebarLayout.astro";
import DocsLayout from "@layouts/DocsLayout.astro";
import type { Locale } from "@i18n/index";
import { t, languages } from "@i18n/index";
import {
  categories,
  getGroupedGuides,
  getGuideEntryUrl,
  getDifficultyBadgeClass,
  getIndexEntry,
  getBase,
} from "@lib/guides";
import { getLastModified, getContributors } from "@lib/git";
import type { Category } from "@lib/guides";
import { LayoutGrid, List } from "@lucide/astro";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of Object.keys(languages)) {
    for (const category of categories) {
      paths.push({ params: { locale, category } });
    }
  }
  return paths;
}

const { locale, category } = Astro.params as {
  locale: Locale;
  category: Category;
};
const base = getBase();

const indexEntry = await getIndexEntry(locale, category);
const guideGroups = await getGroupedGuides(locale, category);

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let headings: { depth: number; slug: string; text: string }[] = [];

if (indexEntry) {
  const rendered = await render(indexEntry);
  Content = rendered.Content;
  headings = rendered.headings;
}

const repoBase = REPO_URL;
const filePath = indexEntry?.filePath ?? "";
const editUrl = indexEntry ? `${repoBase}/edit/main/${filePath}` : undefined;
const issueUrl = indexEntry
  ? `${repoBase}/issues/new?title=Issue+with:+${encodeURIComponent(indexEntry.data.title)}`
  : undefined;

const categoryTitle = t(locale, `categories.${category}.title` as const);
const categoryDescription = t(
  locale,
  `categories.${category}.description` as const,
);

const indexFilePath = indexEntry?.filePath ?? "";
const lastModified = indexFilePath ? getLastModified(indexFilePath) : undefined;
const contributors = indexFilePath ? getContributors(indexFilePath) : [];
---

{
  indexEntry && Content ? (
    <DocsLayout
      title={indexEntry.data.title}
      description={indexEntry.data.description}
      locale={locale}
      category={category}
      guideGroups={guideGroups}
      activeGuideSlug=""
      headings={headings}
      editUrl={editUrl ?? ""}
      issueUrl={issueUrl ?? ""}
      lastModified={lastModified}
      contributors={contributors}
    >
      <Content />
    </DocsLayout>
  ) : (
    <SidebarLayout
      title={categoryTitle}
      locale={locale}
      category={category}
      guideGroups={guideGroups}
    >
      <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8 lg:px-10">
        <h1 class="text-3xl font-bold">{categoryTitle}</h1>
        <p class="mt-2 text-base-content/60">{categoryDescription}</p>

        {guideGroups.length > 0 ? (
          <>
            {/* View toggle */}
            <div class="mt-6 flex justify-end gap-1">
              <button
                id="view-grid"
                class="btn btn-ghost btn-sm btn-active"
                aria-label="Grid view"
              >
                <LayoutGrid class="h-4 w-4" />
              </button>
              <button
                id="view-list"
                class="btn btn-ghost btn-sm"
                aria-label="List view"
              >
                <List class="h-4 w-4" />
              </button>
            </div>

            {/* Guide listing container */}
            <div id="guide-listing" data-view="grid">
              {/* Grid view */}
              <div class="guide-grid mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {guideGroups.map((group) => {
                  const firstEntry = group.entries[0];
                  const href = getGuideEntryUrl(
                    base,
                    locale,
                    category,
                    firstEntry,
                  );
                  const difficulty = group.difficulty;
                  const badgeClass = getDifficultyBadgeClass(difficulty);
                  return (
                    <a
                      href={href}
                      class="card bg-base-200 shadow-sm transition-shadow hover:shadow-md"
                    >
                      <div class="card-body">
                        <h2 class="card-title text-lg">{group.guideTitle}</h2>
                        {group.guideDescription && (
                          <p class="text-sm text-base-content/70">
                            {group.guideDescription}
                          </p>
                        )}
                        <div class="card-actions mt-2">
                          {difficulty && (
                            <span class={`badge badge-sm ${badgeClass}`}>
                              {t(
                                locale,
                                `guide.difficulty.${difficulty}` as const,
                              )}
                            </span>
                          )}
                          {firstEntry.data.readingTime && (
                            <span class="badge badge-ghost badge-sm">
                              {t(locale, "guide.readingTime").replace(
                                "{minutes}",
                                String(firstEntry.data.readingTime),
                              )}
                            </span>
                          )}
                        </div>
                      </div>
                    </a>
                  );
                })}
              </div>

              {/* List view */}
              <div class="guide-list mt-4 hidden divide-y divide-base-300">
                {guideGroups.map((group) => {
                  const firstEntry = group.entries[0];
                  const href = getGuideEntryUrl(
                    base,
                    locale,
                    category,
                    firstEntry,
                  );
                  const difficulty = group.difficulty;
                  const badgeClass = getDifficultyBadgeClass(difficulty);
                  return (
                    <a
                      href={href}
                      class="flex items-center gap-4 px-2 py-3 transition-colors hover:bg-base-200 first:rounded-t-lg last:rounded-b-lg"
                    >
                      <div class="min-w-0 flex-1">
                        <span class="font-medium">{group.guideTitle}</span>
                        {group.guideDescription && (
                          <p class="mt-0.5 truncate text-sm text-base-content/60">
                            {group.guideDescription}
                          </p>
                        )}
                      </div>
                      <div class="flex shrink-0 items-center gap-2">
                        {difficulty && (
                          <span class={`badge badge-sm ${badgeClass}`}>
                            {t(
                              locale,
                              `guide.difficulty.${difficulty}` as const,
                            )}
                          </span>
                        )}
                        {firstEntry.data.readingTime && (
                          <span class="badge badge-ghost badge-sm">
                            {t(locale, "guide.readingTime").replace(
                              "{minutes}",
                              String(firstEntry.data.readingTime),
                            )}
                          </span>
                        )}
                      </div>
                      <span class="text-base-content/30">&rarr;</span>
                    </a>
                  );
                })}
              </div>
            </div>
          </>
        ) : (
          <div class="mt-12 text-center">
            <p class="text-base-content/60">{t(locale, "guide.comingSoon")}</p>
          </div>
        )}
      </main>
    </SidebarLayout>
  )
}

<script>
  const gridBtn = document.getElementById("view-grid");
  const listBtn = document.getElementById("view-list");
  const listing = document.getElementById("guide-listing");

  if (gridBtn && listBtn && listing) {
    const gridEl = listing.querySelector(".guide-grid") as HTMLElement;
    const listEl = listing.querySelector(".guide-list") as HTMLElement;

    function setView(view: "grid" | "list") {
      listing.dataset.view = view;
      if (view === "grid") {
        gridEl.classList.remove("hidden");
        listEl.classList.add("hidden");
        gridBtn.classList.add("btn-active");
        listBtn.classList.remove("btn-active");
      } else {
        gridEl.classList.add("hidden");
        listEl.classList.remove("hidden");
        listBtn.classList.add("btn-active");
        gridBtn.classList.remove("btn-active");
      }
      localStorage.setItem("guide-view", view);
    }

    gridBtn.addEventListener("click", () => setView("grid"));
    listBtn.addEventListener("click", () => setView("list"));

    // Restore saved preference
    const saved = localStorage.getItem("guide-view");
    if (saved === "list") setView("list");
  }
</script>

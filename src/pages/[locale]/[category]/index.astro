---
import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import CategoryTabs from "@components/CategoryTabs.astro";
import Footer from "@components/Footer.astro";
import type { Locale } from "@i18n/index";
import { t, languages } from "@i18n/index";
import {
  categories,
  getGuidesByCategory,
  getGuideSlug,
} from "@lib/guides";
import type { Category } from "@lib/guides";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of Object.keys(languages)) {
    for (const category of categories) {
      paths.push({ params: { locale, category } });
    }
  }
  return paths;
}

const { locale, category } = Astro.params as {
  locale: Locale;
  category: Category;
};
import { getBase } from "@lib/guides";
const base = getBase();

const guides = await getGuidesByCategory(locale, category);
const hasGuides = guides.length > 0;
const redirectUrl = hasGuides
  ? `${base}${locale}/${category}/${getGuideSlug(guides[0].id)}`
  : undefined;
---

{
  redirectUrl ? (
    <html lang={locale}>
      <head>
        <meta charset="utf-8" />
        <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
        <link rel="canonical" href={redirectUrl} />
        <title>Redirecting...</title>
      </head>
      <body>
        <p>
          Redirecting to <a href={redirectUrl}>{redirectUrl}</a>...
        </p>
      </body>
    </html>
  ) : (
    <BaseLayout
      title={t(locale, `categories.${category}.title` as const)}
      locale={locale}
    >
      <div class="flex min-h-screen flex-col">
        <Navbar locale={locale} />
        <CategoryTabs locale={locale} activeCategory={category} />
        <main class="flex flex-1 items-center justify-center p-8">
          <div class="text-center">
            <h1 class="text-2xl font-bold">
              {t(locale, `categories.${category}.title` as const)}
            </h1>
            <p class="mt-2 text-base-content/60">
              {t(locale, "guide.comingSoon")}
            </p>
          </div>
        </main>
        <Footer locale={locale} />
      </div>
    </BaseLayout>
  )
}

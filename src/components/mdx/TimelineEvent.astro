---
import * as lucide from "@lucide/astro";
import type { AstroComponent } from "@lucide/astro/src/types";

interface Props {
  time: string;
  icon: string;
}

const { time, icon } = Astro.props;

const pascalName = icon
  .split("-")
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join("");

const iconMap = new Map(
  Object.entries(lucide).filter(
    (entry): entry is [string, AstroComponent] =>
      typeof entry[1] === "function",
  ),
);

const Icon = iconMap.get(pascalName) ?? lucide.CircleHelp;
---

<div class="relative pl-8 pb-6 last:pb-0">
  <div
    class="absolute -left-[13px] top-0.5 w-6 h-6 rounded-full bg-primary flex items-center justify-center"
  >
    <Icon class="w-3.5 h-3.5 text-primary-content" />
  </div>
  <div class="font-bold text-sm text-primary mb-1">{time}</div>
  <div class="text-base-content/80"><slot /></div>
</div>

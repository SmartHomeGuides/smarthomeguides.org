---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";
import SearchBar from "@components/SearchBar.astro";
import LanguageSwitcher from "@components/LanguageSwitcher.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
import { getBase } from "@lib/guides";
const base = getBase();
const currentPath = Astro.url.pathname;
---

<header class="navbar sticky top-0 z-50 border-b border-base-300 bg-base-100">
  {/* Left: hamburger + logo */}
  <div class="navbar-start gap-2">
    <label for="sidebar-drawer" class="btn btn-ghost btn-sm lg:hidden">
      <svg
        class="h-5 w-5"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </label>
    <a href={`${base}${locale}/guides`} class="flex items-center gap-2 text-lg font-bold">
      <span>{t(locale, "nav.title")}</span>
      <span class="badge badge-primary badge-sm">{t(locale, "nav.subtitle")}</span>
    </a>
  </div>

  {/* Center: search */}
  <div class="navbar-center hidden md:flex">
    <SearchBar locale={locale} />
  </div>

  {/* Right: language + github */}
  <div class="navbar-end gap-1">
    <LanguageSwitcher locale={locale} currentPath={currentPath} />
    <a
      href="https://github.com/smarthomeguides/smarthomeguides.org"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-ghost btn-sm"
      aria-label={t(locale, "nav.github")}
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path>
      </svg>
    </a>
  </div>
</header>

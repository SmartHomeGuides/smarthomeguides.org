---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";
import SearchBar from "@components/SearchBar.astro";
import LanguageSwitcher from "@components/LanguageSwitcher.astro";
import { Menu, Sun, Moon, Github, Search } from "@lucide/astro";
import { REPO_URL } from "@lib/consts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
import { getBase } from "@lib/guides";
const base = getBase();
const currentPath = Astro.url.pathname;
---

<header class="navbar sticky top-0 z-50 border-b border-base-300 bg-base-100">
  {/* Left: hamburger + logo */}
  <div class="navbar-start gap-2">
    <label
      for="sidebar-drawer"
      class="btn btn-ghost btn-sm hidden"
      id="sidebar-toggle"
    >
      <Menu class="h-5 w-5" />
    </label>
    <a
      href={`${base}${locale}/guides`}
      class="flex flex-col items-center text-lg font-bold sm:flex-row sm:gap-2"
    >
      <span>{t(locale, "nav.title")}</span>
      <span class="badge badge-primary badge-sm"
        >{t(locale, "nav.subtitle")}</span
      >
    </a>
  </div>

  {/* Center: search */}
  <div class="navbar-center hidden md:flex">
    <SearchBar locale={locale} />
  </div>

  {/* Right: search (mobile) + theme + language + github */}
  <div class="navbar-end gap-1">
    <button
      class="btn btn-ghost btn-sm md:hidden"
      aria-label="Search"
      id="search-trigger-mobile"
    >
      <Search class="h-5 w-5" />
    </button>
    <button
      id="theme-toggle"
      class="btn btn-ghost btn-sm"
      aria-label="Toggle theme"
    >
      {/* Sun icon (shown in dark mode) */}
      <span id="theme-sun" class="hidden">
        <Sun class="h-5 w-5" />
      </span>
      {/* Moon icon (shown in light mode) */}
      <span id="theme-moon">
        <Moon class="h-5 w-5" />
      </span>
    </button>
    <LanguageSwitcher locale={locale} currentPath={currentPath} />
    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-ghost btn-sm"
      aria-label={t(locale, "nav.github")}
    >
      <Github class="h-5 w-5" />
    </a>
  </div>
</header>

<script>
  // Show burger menu only when the sidebar drawer exists on the page
  const toggle = document.getElementById("sidebar-toggle");
  if (toggle && document.getElementById("sidebar-drawer")) {
    toggle.classList.remove("hidden");
  }

  function updateIcons(theme: string) {
    const sun = document.getElementById("theme-sun");
    const moon = document.getElementById("theme-moon");
    if (sun && moon) {
      sun.classList.toggle("hidden", theme === "light");
      moon.classList.toggle("hidden", theme === "dark");
    }
  }

  updateIcons(document.documentElement.getAttribute("data-theme") || "light");

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
    updateIcons(next);
  });
</script>

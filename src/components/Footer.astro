---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="border-t border-base-300 bg-base-100">
  <div class="mx-auto flex max-w-[1400px] flex-col items-center gap-2 px-4 py-6 text-sm text-base-content/60 sm:flex-row sm:justify-between">
    <p>{t(locale, "footer.openSource")}</p>
    <p>{t(locale, "footer.license")}</p>
    <a
      href="https://github.com/smarthomeguides/smarthomeguides.org"
      target="_blank"
      rel="noopener noreferrer"
      class="link link-hover"
    >
      GitHub
    </a>
  </div>
</footer>

---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";
import { categories } from "@lib/guides";
import type { Category } from "@lib/guides";
import { getBase } from "@lib/guides";
import { SITE_URL } from "@lib/consts";
import { ChevronDown, House } from "@lucide/astro";

interface Props {
  locale: Locale;
  category?: Category;
  guideTitle?: string;
  chapterTitle?: string;
  guideHref?: string;
}

const { locale, category, guideTitle, chapterTitle, guideHref } = Astro.props;
const base = getBase();

const siteOrigin = Astro.site?.origin ?? SITE_URL;

// Build breadcrumb items for JSON-LD
const crumbs: { name: string; href: string }[] = [
  { name: t(locale, "nav.home"), href: `${base}${locale}/` },
  { name: t(locale, "nav.guides"), href: `${base}${locale}/guides` },
];
if (category) {
  crumbs.push({
    name: t(locale, `categories.${category}.title` as const),
    href: `${base}${locale}/guides/${category}/`,
  });
}
if (guideTitle) {
  if (chapterTitle && guideHref) {
    crumbs.push({ name: guideTitle, href: guideHref });
    crumbs.push({ name: chapterTitle, href: Astro.url.pathname });
  } else {
    crumbs.push({ name: guideTitle, href: Astro.url.pathname });
  }
}

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: crumbs.map((c, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: c.name,
    item: new URL(c.href, siteOrigin).href,
  })),
});
---

<div
  class="sticky top-[64px] z-40 -mx-4 bg-base-100 px-4 py-2 lg:-mx-10 lg:px-10"
>
  <div class="breadcrumbs text-sm overflow-visible">
    <ul>
      <li>
        <a href={`${base}${locale}/`} aria-label={t(locale, "nav.home")}
          ><House class="h-4 w-4" /></a
        >
      </li>
      <li>
        <a href={`${base}${locale}/guides`}>{t(locale, "nav.guides")}</a>
      </li>
      {
        category && (
          <li>
            <div class="dropdown dropdown-bottom">
              <div
                tabindex="0"
                role="button"
                class="btn btn-ghost btn-xs gap-1 border border-base-300"
              >
                {t(locale, `categories.${category}.title` as const)}
                <ChevronDown class="h-3 w-3" />
              </div>
              <ul
                tabindex="0"
                class="dropdown-content z-50 menu menu-sm mb-1 w-44 rounded-box bg-base-200 p-1 shadow-lg"
              >
                {categories.map((cat) => (
                  <li>
                    <a
                      href={`${base}${locale}/guides/${cat}/`}
                      class:list={{ active: cat === category }}
                    >
                      {t(locale, `categories.${cat}.title` as const)}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        )
      }
      {
        guideTitle &&
          (chapterTitle && guideHref ? (
            <>
              <li>
                <a href={guideHref}>{guideTitle}</a>
              </li>
              <li>{chapterTitle}</li>
            </>
          ) : (
            <li>{guideTitle}</li>
          ))
      }
    </ul>
  </div>
</div>
<script is:inline type="application/ld+json" set:html={breadcrumbSchema} />

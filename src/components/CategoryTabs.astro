---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";
import { categories } from "@lib/guides";
import type { Category } from "@lib/guides";

interface Props {
  locale: Locale;
  activeCategory?: Category;
}

const { locale, activeCategory } = Astro.props;
import { getBase } from "@lib/guides";
const base = getBase();
---

<nav class="sticky top-[64px] z-40 border-b border-base-300 bg-base-100">
  <div class="mx-auto max-w-[1400px] overflow-x-auto px-4">
    <div role="tablist" class="tabs tabs-border">
      {
        categories.map((cat) => (
          <a
            role="tab"
            href={`${base}${locale}/guides/${cat}/`}
            class:list={["tab", { "tab-active": cat === activeCategory }]}
          >
            {t(locale, `categories.${cat}.title` as const)}
          </a>
        ))
      }
    </div>
  </div>
</nav>

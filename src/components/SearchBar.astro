---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";
import { Search } from "@lucide/astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="form-control">
  <button
    id="search-trigger"
    type="button"
    class="input input-sm input-bordered flex w-full max-w-xs cursor-pointer items-center gap-2 pl-3 text-sm text-base-content/40"
  >
    <Search class="h-4 w-4 shrink-0" />
    <span class="flex-1 text-left">{t(locale, "search.placeholder")}</span>
    <kbd class="kbd kbd-sm">⌘K</kbd>
  </button>
</div>

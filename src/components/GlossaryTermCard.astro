---
interface Props {
  title: string;
  description?: string;
  href: string;
  relatedGuideCount: number;
}

const { title, description, href, relatedGuideCount } = Astro.props;
---

<a
  href={href}
  class="glossary-term card bg-base-200 shadow-sm transition-shadow hover:shadow-md"
  data-term={title}
  data-description={description ?? ""}
>
  <div class="card-body p-4">
    <div class="flex items-start justify-between gap-2">
      <h3 class="card-title text-base">{title}</h3>
      {
        relatedGuideCount > 0 && (
          <span class="badge badge-ghost badge-sm shrink-0">
            {relatedGuideCount} {relatedGuideCount === 1 ? "guide" : "guides"}
          </span>
        )
      }
    </div>
    {
      description && (
        <p class="line-clamp-2 text-sm text-base-content/70">{description}</p>
      )
    }
  </div>
</a>

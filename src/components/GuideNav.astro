---
import type { Locale } from "@i18n/index";
import { t } from "@i18n/index";

interface GuideLink {
  href: string;
  title: string;
}

interface Props {
  locale: Locale;
  prev?: GuideLink;
  next?: GuideLink;
}

const { locale, prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav class="mt-12 grid grid-cols-1 gap-4 border-t border-base-300 pt-6 sm:grid-cols-2">
      {prev ? (
        <a
          href={prev.href}
          class="group flex flex-col rounded-lg border border-base-300 p-4 transition-colors hover:border-primary"
        >
          <span class="text-xs text-base-content/50">
            ← {t(locale, "guide.previous")}
          </span>
          <span class="mt-1 font-medium group-hover:text-primary">
            {prev.title}
          </span>
        </a>
      ) : (
        <div />
      )}
      {next && (
        <a
          href={next.href}
          class="group flex flex-col items-end rounded-lg border border-base-300 p-4 text-right transition-colors hover:border-primary"
        >
          <span class="text-xs text-base-content/50">
            {t(locale, "guide.next")} →
          </span>
          <span class="mt-1 font-medium group-hover:text-primary">
            {next.title}
          </span>
        </a>
      )}
    </nav>
  )
}

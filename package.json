{
  "name": "smarthomeguides.org",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "astro": "^6.0.4",
    "@astrojs/mdx": "^5.0.0",
    "@tailwindcss/vite": "^4.1.10",
    "tailwindcss": "^4.1.10",
    "daisyui": "^5.0.43"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-config-prettier": "^10.1.5",
    "typescript-eslint": "^8.35.0",
    "typescript": "^5.8.3",
    "@types/node": "^24.0.3"
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
